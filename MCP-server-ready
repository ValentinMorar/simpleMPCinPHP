<?php
// mcp-server.php
// Deploy to any shared hosting with PHP and Apache
// No special extensions or persistent processes required

declare(strict_types=1);

// Security — validate bearer token
function authenticate(): void {
    $headers = getallheaders();
    $auth = $headers['Authorization'] ?? $headers['authorization'] ?? '';
    
    if ($auth !== 'Bearer ' . MCP_SECRET_TOKEN) {
        http_response_code(401);
        echo json_encode([
            'jsonrpc' => '2.0',
            'error' => [
                'code' => -32001,
                'message' => 'Unauthorized'
            ]
        ]);
        exit;
    }
}

// Send JSON-RPC response
function send_response(mixed $id, mixed $result): void {
    echo json_encode([
        'jsonrpc' => '2.0',
        'id' => $id,
        'result' => $result
    ], JSON_UNESCAPED_UNICODE);
}

// Send JSON-RPC error
function send_error(mixed $id, int $code, string $message): void {
    echo json_encode([
        'jsonrpc' => '2.0',
        'id' => $id,
        'error' => ['code' => $code, 'message' => $message]
    ], JSON_UNESCAPED_UNICODE);
}

// Tool: search products
function tool_search_products(array $args): array {
    $query      = $args['query'] ?? '';
    $price_max  = $args['price_max'] ?? null;
    $in_stock   = $args['in_stock'] ?? false;
    $lat        = $args['location_lat'] ?? null;
    $lng        = $args['location_lng'] ?? null;
    $radius_km  = $args['radius_km'] ?? 10;

    // 1. Generate sign vector for query (call Claude API)
    $sign_vector = generate_sign_vector($query);

    // 2. Build SQL with sign vector similarity + filters
    $pdo = get_database_connection();

    $sql = "SELECT p.*,
            sign_similarity(p.sign_vector, :sv) AS score
            FROM products p
            WHERE 1=1";

    $params = [':sv' => json_encode($sign_vector)];

    if ($price_max !== null) {
        $sql .= " AND p.price <= :price_max";
        $params[':price_max'] = $price_max;
    }

    if ($in_stock) {
        $sql .= " AND p.stock_quantity > 0";
    }

    if ($lat !== null && $lng !== null) {
        $sql .= " AND store_distance(p.store_id, :lat, :lng) <= :radius";
        $params[':lat']    = $lat;
        $params[':lng']    = $lng;
        $params[':radius'] = $radius_km;
    }

    $sql .= " ORDER BY score DESC LIMIT 10";

    $stmt = $pdo->prepare($sql);
    $stmt->execute($params);
    $products = $stmt->fetchAll(PDO::FETCH_ASSOC);

    return [
        'content' => [[
            'type' => 'text',
            'text' => json_encode($products, JSON_UNESCAPED_UNICODE)
        ]]
    ];
}

// ── Bootstrap ──────────────────────────────────────────────

define('MCP_SECRET_TOKEN', getenv('MCP_SECRET_TOKEN') ?: 'your-secret-token');

header('Content-Type: application/json; charset=utf-8');
header('Access-Control-Allow-Origin: *');
header('Access-Control-Allow-Headers: Content-Type, Authorization');

if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
    http_response_code(200);
    exit;
}

authenticate();

$raw   = file_get_contents('php://input');
$input = json_decode($raw, true);

if (!$input || !isset($input['method'])) {
    send_error(null, -32700, 'Parse error');
    exit;
}

$method = $input['method'];
$id     = $input['id'] ?? null;
$params = $input['params'] ?? [];

// ── Router ─────────────────────────────────────────────────

switch ($method) {

    case 'initialize':
        send_response($id, [
            'protocolVersion' => '2024-11-05',
            'capabilities'    => ['tools' => []],
            'serverInfo'      => [
                'name'    => 'product-search-mcp',
                'version' => '1.0.0'
            ]
        ]);
        break;

    case 'tools/list':
        send_response($id, [
            'tools' => [[
                'name'        => 'search_products',
                'description' => 'Search product catalog using semantic
                                  similarity across ingredient properties,
                                  skin type compatibility, price range,
                                  and real-time stock by location.
                                  Understands natural language queries
                                  including ingredient exclusions and
                                  consumer health requirements.',
                'inputSchema' => [
                    'type'       => 'object',
                    'properties' => [
                        'query' => [
                            'type'        => 'string',
                            'description' => 'Natural language search query'
                        ],
                        'price_max' => [
                            'type'        => 'number',
                            'description' => 'Maximum price in local currency'
                        ],
                        'in_stock' => [
                            'type'        => 'boolean',
                            'description' => 'Return only products in stock'
                        ],
                        'location_lat' => ['type' => 'number'],
                        'location_lng' => ['type' => 'number'],
                        'radius_km'    => [
                            'type'        => 'number',
                            'description' => 'Search radius in kilometers'
                        ]
                    ],
                    'required' => ['query']
                ]
            ]]
        ]);
        break;

    case 'tools/call':
        $tool_name = $params['name'] ?? '';
        $tool_args = $params['arguments'] ?? [];

        if ($tool_name === 'search_products') {
            $result = tool_search_products($tool_args);
            send_response($id, $result);
        } else {
            send_error($id, -32602, "Unknown tool: {$tool_name}");
        }
        break;

    default:
        send_error($id, -32601, "Method not found: {$method}");
}
